<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE Plugin PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Plugin displayName="IDW Query Plugin" minSystemVersion="8.0" name="IDWQueryPlugin" version="%%BUILD_VERSION%%" rightRequired="IDW_SP_QueryRunner">
  <Attributes>
    <Map>
      <entry key="minUpgradableVersion" value="1.0" />
      <entry key="fullPage">
        <value>
          <FullPage title="IDW IIQ Query" />
        </value>
      </entry>
      <entry key="serviceExecutors"/>
      <entry key="restResources">
        <value>
          <List>
            <String>com.identityworksllc.iiq.plugins.queryplugin.QueryPluginResource</String>
            <String>com.identityworksllc.iiq.plugins.queryplugin.ScriptExecutionResource</String>
            <String>com.identityworksllc.iiq.plugins.queryplugin.reporting.SaveReportResource</String>
          </List>
        </value>
      </entry>
      <entry key="settings">
        <value>
          <List>
            <Setting dataType="boolean" helpText="If checked, execution against JDBC applications will be enabled" label="Enable querying JDBC applications" name="enableJdbcAppQuery" defaultValue="true"/>
            <Setting dataType="boolean" helpText="If checked, the SQL script execution endpoint will be enabled" label="Enable SQL script execution" name="enableScriptExecution" defaultValue="false"/>
          </List>
        </value>
      </entry>
    </Map>
  </Attributes>
</Plugin>

